{
  "name": "home-library",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted personal book tracker with ISBN auto-enrichment and barcode scanning",
  "scripts": {
    "dev:server": "node --watch server/index.js",
    "dev:web": "vite",
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "build": "vite build",
    "start": "node server/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "html5-qrcode": "^2.3.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  }
}
